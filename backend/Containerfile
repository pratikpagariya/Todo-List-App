# Backend — Node.js/Express API. Buildah/Podman compatible (standard syntax).
# Multi-stage: install prod deps, then a slim non-root runtime image.
FROM docker.io/library/node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

FROM docker.io/library/node:20-alpine AS runtime
ENV NODE_ENV=production
WORKDIR /app
# Patch OS packages (libcrypto3/libssl3, etc.) and remove the globally-bundled
# npm — its glob/tar/cross-spawn/minimatch carry CVEs and aren't needed at
# runtime (the app starts with `node`, not `npm`).
RUN apk --no-cache upgrade \
 && rm -rf /usr/local/lib/node_modules/npm /usr/local/bin/npm /usr/local/bin/npx
COPY --chown=node:node --from=deps /app/node_modules ./node_modules
COPY --chown=node:node . .
USER node
EXPOSE 3000
CMD ["node", "src/server.js"]
