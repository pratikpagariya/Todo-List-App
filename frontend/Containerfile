# Frontend — build the Vite app, serve the static bundle with UNPRIVILEGED nginx.
# Buildah/Podman compatible (standard syntax). Multi-stage keeps Node out of the
# final image (smaller, fewer CVEs).
FROM docker.io/library/node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build                 # outputs to /app/dist

FROM docker.io/nginxinc/nginx-unprivileged:1.27-alpine AS runtime
# Patch OS packages (libcrypto3/libssl3, etc.) as root, then drop back to nginx.
USER 0
RUN apk --no-cache upgrade
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
# Explicit non-root user (uid 101 = "nginx" in nginx-unprivileged). Satisfies
# Trivy DS002 and matches the Deployment's runAsUser: 101.
USER 101
EXPOSE 8080                       # nginx-unprivileged listens on 8080 as uid 101
